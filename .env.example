# Конфигурация Ollama
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=mistral
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# Конфигурация Whisper
WHISPER_MODEL_SIZE=base
DEVICE=cpu

# Конфигурация TTS
TTS_ENGINE=piper
TTS_VOICE=uk_UA-mykyta-x_low
TTS_SPEED=1.0

# Режим работы: cli, api, web
APP_MODE=cli
APP_HOST=0.0.0.0
APP_PORT=8000
APP_DEBUG=true

# Путь к медицинской БЗ
MEDICAL_KB_PATH=./data/medical_kb
VECTORS_PATH=./data/vectors

# RAG параметры
CHUNK_SIZE=1000
CHUNK_OVERLAP=100
TOP_K_RESULTS=3

# Языки
UI_LANGUAGE=uk
MODEL_LANGUAGE=en
